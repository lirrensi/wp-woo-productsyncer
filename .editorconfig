# ── Woo Product Syncer — EditorConfig ──────────────────────────
# Keep consistent coding styles across all editors and IDEs.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{php,inc}]
indent_style = tab
indent_size = 4

[*.{json,yml,yaml,js,css,scss,less,html,xml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
indent_size = 4

[*.ps1]
indent_style = space
indent_size = 4

[*.{png,jpg,gif,svg,ico,woff,woff2,ttf,eot}]
insert_final_newline = false
