<?xml version="1.0"?>
<ruleset name="Woo Product Syncer">
    <description>PHP_CodeSniffer rules for Woo Product Syncer</description>

    <file>.</file>

    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>dist/</exclude-pattern>
    <exclude-pattern>tests/</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.min.css</exclude-pattern>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- Use WordPress-Extra as the base -->
    <rule ref="WordPress-Extra">
        <!-- Allow short ternary -->
        <exclude name="WordPress.PHP.DisallowShortTernary"/>
        <!-- Allow file get/put calls for WP options API wrappers -->
        <exclude name="WordPress.WP.AlternativeFunctions"/>
    </rule>

    <!-- Require short array syntax -->
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

    <!-- Require spaces around double arrow -->
    <rule ref="Generic.Arrays.ArrayIndent"/>

    <!-- Check for TODO/FIXME tags -->
    <rule ref="Generic.Commenting.Todo"/>

    <!-- No PHP closing tags -->
    <rule ref="PSR2.Files.ClosingTag"/>

    <!-- Line endings -->
    <rule ref="Generic.Files.LineEndings">
        <properties>
            <property name="eolChar" value="\n"/>
        </properties>
    </rule>

    <!-- PHP cross-version compatibility -->
    <rule ref="PHPCompatibility">
        <config name="testVersion" value="7.4-"/>
    </rule>
</ruleset>
